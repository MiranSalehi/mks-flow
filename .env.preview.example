# MKSFlow shared preview — copy to .env.preview for local runs.
# Production deploy injects these values; use placeholders only in git.

# Public preview slot URL (host nginx proxies to the container).
PREVIEW_URL=https://your-slot.preview.mksflow.com
PREVIEW_SLOT=your-slot-id
APP_URL=https://your-slot.preview.mksflow.com

# Host MySQL via Docker host gateway (phase 1: no DB container in compose).
# Reserved for future team/cloud sync preview; extension runtime uses local SQLite.
DB_HOST=host.docker.internal
DB_DATABASE=mksflow_preview
DB_USERNAME=mksflow_preview
DB_PASSWORD=your_password_here

# Container runtime
PORT=8080
NODE_ENV=production
